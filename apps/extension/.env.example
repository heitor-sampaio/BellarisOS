# Copie para .env e preencha. Todos são públicos (embutidos no bundle da extensão).

# URL e anon key do Supabase (mesmos NEXT_PUBLIC_* do app web)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Base do app Bellaris (onde vivem as rotas /api/ext). Ex.: http://localhost:3000 em dev,
# https://app.bellaris.com.br em produção.
VITE_API_BASE=http://localhost:3000
